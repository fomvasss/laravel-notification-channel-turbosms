{
    "name": "fomvasss/laravel-notification-channel-turbo-sms",
    "description": "This package makes it easy to send notifications using [turbosms.ua](https://turbosms.ua) with Laravel",
    "homepage": "https://github.com/fomvasss/laravel-notification-channel-turbo-sms",
    "keywords": ["laravel", "notifications", "sms", "turbo-sms", "ТурбоСМС"],
    "license": "MIT",
    "funding": [
        {
            "type": "custom",
            "url": "https://send.monobank.ua/jar/5xsqtHvVrY"
        },
        {
            "type": "ko_fi",
            "url": "https://ko-fi.com/fomvasss"
        }
    ],
    "authors": [
        {
            "name": "Fomin Vasil",
            "email": "fomvasss@gmail.com",
            "homepage": "https://github.com/fomvasss",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/notifications": "^10|^11|^12|^13",
        "illuminate/support": "^10|^11|^12|^13"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "NotificationChannels\\TurboSms\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NotificationChannels\\TurboSms\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "NotificationChannels\\TurboSms\\TurboSmsServiceProvider"
            ]
        }
    }
}
